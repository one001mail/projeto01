{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "Modular Fastify + TypeScript backend (Clean Architecture / DDD)",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').cpSync('src/infra/db/migrations','dist/infra/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --dir src --exclude '**/*.integration.test.ts' --exclude '**/*.e2e.test.ts'",
    "test:integration": "vitest run --dir src --testNamePattern integration",
    "test:e2e": "vitest run --dir tests/e2e",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "check:boundaries": "tsx tools/check-boundaries.ts",
    "check:arch": "npm run check:boundaries && npm run typecheck",
    "migrate": "tsx src/infra/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/node": "^20.14.13",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5"
  }
}
